# ============================================================
# foodcosting.app — Agent Environment Variables (EXAMPLE)
# ============================================================
# Copy this file to .env and fill in your real keys.
# This file is safe to commit — it contains no real secrets.
# ============================================================

# --- Firecrawl ---
FIRECRAWL_API_KEY=

# --- ElevenLabs (for AI voiceover) ---
ELEVENLABS_API_KEY=

# --- Exa (semantic search — add when ready) ---
EXA_API_KEY=

# --- Notion (content + community databases) ---
NOTION_API_KEY=
NOTION_REDDIT_SUBREDDITS_DATABASE_ID=
NOTION_REDDIT_SUBREDDITS_DATA_SOURCE_ID=
NOTION_SEO_OPPORTUNITIES_DATABASE_ID=
NOTION_SEO_OPPORTUNITIES_DATA_SOURCE_ID=
NOTION_VERSION=2022-06-28

# --- Google Search Console ---
GSC_SERVICE_ACCOUNT_PATH=credentials/gsc_service_account.json
GSC_SITE_URL=sc-domain:foodcosting.app

# --- Reddit (community monitor) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=windows:foodcosting-community-monitor:v0.1.0 (by /u/<reddit_username>)

# --- Buffer (social media scheduling) ---
BUFFER_API_TOKEN=
BUFFER_ORG_ID=
BUFFER_CHANNEL_INSTAGRAM=
BUFFER_CHANNEL_YOUTUBE=
BUFFER_CHANNEL_FACEBOOK=
# Optional future channel. V1 prioritizes Facebook over LinkedIn.
BUFFER_CHANNEL_LINKEDIN=

# --- Unsplash (blog header images) ---
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# --- Cloudinary (image optimization) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
